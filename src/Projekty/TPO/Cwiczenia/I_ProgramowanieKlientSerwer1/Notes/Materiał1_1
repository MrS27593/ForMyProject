Zaczniemy od prostej komunikacji typu ECHO. Obecnie interakcje na porcie 7 są ogólnie wyłączone ze względów bezpieczeństwa, ale dla celów testowych powstały proste serwery ECHO, komunikujace się na innych portach.
Sekwencję interakcji klient-serwer dobrze ilustruje poniższy programik.

Kopiuj
import java.io.*;
import java.net.*;

public class EchoClient {
  public static void main(String[] args) {
    String host = "45.79.112.203" // "tcpbin.org"
    int port = 4242; // zamiast zazwyczaj blokowanego 7

    // Try-with-resources zamknie gniazdo i automatycznie
    // powiązane z nimi strumienie
    try (Socket socket = new Socket(host, port)) {

      // Strumienie gniazda - do zapisu i odczytu
      OutputStream sos = socket.getOutputStream();
      PrintWriter out = new PrintWriter(sos, true);  // true robi flush

      InputStream sins = socket.getInputStream();
      BufferedReader in = new BufferedReader(new InputStreamReader(sins));

      //  Wysłanie wiadomości
      String msg = "Moja wiadomość";
      out.println(msg);
      // Odebranie odpowiedzi
      String resp = in.readLine();
      System.out.println("Odebrano: " + resp);
    } catch (UnknownHostException e) {
      System.err.println("Nie znaleziono hosta: " + host);
    } catch (IOException e) {
      System.err.println("Błąd I/O: " + e.getMessage());
    }
  }
}

